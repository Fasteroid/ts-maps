{
    "name": "@fasteroid/maps",
    "version": "3.1.0",
    "description": "Some extensions and variations of Map<K, V>",
    "main": "index.js",
    "module": "index.js",
    "types": "index.d.ts",
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "test-node": "tsx --test --expose-gc --max-old-space-size=512",
        "test-bun": "bun test --expose-gc --max-old-space-size=512"
    },
    "author": "Fasteroid",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Fasteroid/ts-maps.git"
    },
    "keywords": [
        "map",
        "hashmap",
        "util"
    ],
    "bugs": {
        "url": "https://github.com/Fasteroid/ts-maps/issues"
    },
    "homepage": "https://github.com/Fasteroid/ts-maps#readme",
    "devDependencies": {
        "@types/bun": "^1.3.14",
        "@types/node": "^20.17.6",
        "rxjs": "^7.8.0",
        "tsx": "^4.22.4",
        "typescript": "^5.6.3"
    },
    "files": [

     "**/**.d.ts.map"
    ],
    "exports": {
        "./*": {
            "default": "./*.js",
            "types": "./*.d.ts"
        },
        ".": {
            "default": "./index.js",
            "types": "./index.d.ts"
        }
    }
}
